{
	"author": "Marius Modlich <hi@vexx.sh>",
	"bin": {
		"mcp-docsrs": "./src/main.ts"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "1.29.0",
		"neverthrow": "8.2.0",
		"zod": "4.3.6"
	},
	"description": "MCP server for fetching Rust crate documentation via docs.rs RustDoc API",
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@modelcontextprotocol/inspector": "0.21.2",
		"@types/bun": "1.3.12",
		"husky": "9.1.7",
		"release-please": "17.6.0",
		"typescript": "6.0.3"
	},
	"engines": {
		"bun": "1.3.11"
	},
	"keywords": [
		"mcp",
		"rust",
		"docs",
		"documentation",
		"bun"
	],
	"license": "Apache-2.0",
	"main": "./dist/mcp-docsrs",
	"name": "mcp-docsrs",
	"scripts": {
		"build": "bun run ./scripts/build/script.ts",
		"check": "tsc --noEmit",
		"dev": "bun run src/main.ts",
		"inspect": "mcp-inspector --config mcp-inspector.config.json --server mcp-docsrs",
		"lint": "biome check .",
		"lint:fix": "biome check . --fix",
		"lint:fixunsafe": "biome check . --fix --unsafe",
		"prepare": "husky",
		"start": "./dist/mcp-docsrs"
	},
	"type": "module",
	"version": "0.0.1"
}
