{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"lib": [
			"ES2024"
		],
		"module": "Preserve",
		"moduleResolution": "bundler",
		"noEmit": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"outDir": "./dist",
		"paths": {
			"@mcp-docsrs/*": [
				"./src/*"
			],
			"@mcp-docsrs/errors": [
				"./src/errors/errors.ts"
			],
			"@mcp-docsrs/cache/*": [
				"./src/cache/*"
			],
			"@mcp-docsrs/config/*": [
				"./src/config/*"
			],
			"@mcp-docsrs/docs/*": [
				"./src/docs/*"
			],
			"@mcp-docsrs/prompts/*": [
				"./src/prompts/*"
			],
			"@mcp-docsrs/server/*": [
				"./src/server/*"
			],
			"@mcp-docsrs/tools/*": [
				"./src/tools/*"
			]
		},
		"resolveJsonModule": true,
		"rootDir": ".",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "ES2024",
		"types": [
			"@types/bun"
		],
		"verbatimModuleSyntax": true
	},
	"exclude": [
		"node_modules",
		"dist"
	],
	"include": [
		"src/**/*",
		"scripts/**/*",
		"tests/**/*"
	]
}
